# Database URL (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./leaderboard.db
# DATABASE_URL=postgresql://user:password@localhost/amongus_leaderboard

# S3-compatible storage (MinIO for local, omit endpoint for real AWS S3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=amongus-game-logs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Webhook for game completion notifications (optional)
GAME_COMPLETE_WEBHOOK_URL=

# OpenRouter API key for running games
OPENROUTER_API_KEY=your-openrouter-api-key
